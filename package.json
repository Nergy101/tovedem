{
  "name": "tovedem",
  "version": "1.0.7",
  "scripts": {
    "ng": "ng",
    "start": "node scripts/set-version.mjs && ng serve",
    "start:devcontainer": "node scripts/set-version.mjs && ng serve --host 0.0.0.0",
    "build": "ng build",
    "build:prod": "node scripts/set-version.mjs && ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --no-watch --no-progress --browsers ChromeHeadless",
    "test:ui": "ng test --browsers Chrome",
    "test:pb": "node --test pb_hooks/__tests__/*.test.js",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.5",
    "@angular/cdk": "^22.0.3",
    "@angular/common": "^22.0.5",
    "@angular/compiler": "^22.0.5",
    "@angular/core": "^22.0.5",
    "@angular/forms": "^22.0.5",
    "@angular/language-service": "^22.0.5",
    "@angular/material": "^22.0.3",
    "@angular/platform-browser": "^22.0.5",
    "@angular/platform-browser-dynamic": "^22.0.5",
    "@angular/router": "^22.0.5",
    "apexcharts": "^5.16.0",
    "bootstrap": "^5.3.8",
    "canvas-confetti": "^1.9.4",
    "jquery": "^4.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jszip": "^3.10.1",
    "luxon": "^3.7.2",
    "mdb-angular-ui-kit": "^10.0.0",
    "ng-apexcharts": "^2.4.0",
    "ng-recaptcha": "^13.2.1",
    "ngx-awesome-uploader": "^19.0.1",
    "ngx-material-timepicker": "^13.1.1",
    "ngx-quill": "^31.0.1",
    "ngx-toastr": "^20.0.5",
    "pocketbase": "^0.27.0",
    "quill": "^2.0.3",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.5",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jasmine": "~6.0.0",
    "@types/jszip": "^3.4.1",
    "@types/luxon": "^3.7.2",
    "angular-eslint": "^22.0.0",
    "eslint": "^10.6.0",
    "jasmine-core": "~6.3.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
